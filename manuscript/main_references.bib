@misc{Jewett2023,
	abstract = {The ART report provides an in-depth picture of the type, number, and outcome of ART cycles performed in U.S. fertility clinics. The report includes appendixes containing the results of data validation visits, a glossary, and contact information for reporting and non-reporting clinics in the United States. The data for this national report comes from the 453 fertility clinics in operation in 2021 that provided and verified data on the outcomes of all ART cycles started at their clinics. Based on the ART cycles that were started in 2021, approximately 238,126 patients had 413,776 ART cycles performed at 453 reporting clinics in the United States, resulting in 112,088 clinical pregnancies, 91,906 live births (deliveries of one or more living infants), and 97,128 live born infants. Data provided by U.S. fertility clinics that use ART to treat infertility is a rich source of information about the factors that contribute to a successful ART treatment--the delivery of a healthy infant.},
	author = {Jewett, Amy and Zhang, Yujia and Sunderam, Mithi and Buxton, Charles and Kissin, Dmitry M.},
	howpublished = {https://stacks.cdc.gov},
	langid = {english},
