@article{Little2009,
	abstract = {We consider the analysis of clinical trials that involve randomization to an active treatment (T = 1) or a control treatment (T = 0), when the active treatment is subject to all-or-nothing compliance. We compare three approaches to estimating treatment efficacy in this situation: as-treated analysis, per-protocol analysis, and instrumental variable (IV) estimation, where the treatment effect is estimated using the randomization indicator as an IV. Both model- and method-of-moment based IV estimators are considered. The assumptions underlying these estimators are assessed, standard errors and mean squared errors of the estimates are compared, and design implications of the three methods are examined. Extensions of the methods to include observed covariates are then discussed, emphasizing the role of compliance propensity methods and the contrasting role of covariates in these extensions. Methods are illustrated on data from the Women Take Pride study, an assessment of behavioral treatments for women with heart disease.},
	author = {Little, Roderick J. and Long, Qi and Lin, Xihong},
	eprint = {25502328},
	eprinttype = {jstor},
	journal = {Biometrics},
	number = {2},
	pages = {640--649},
	publisher = {[Wiley, International Biometric Society]},
	title = {A {{Comparison}} of {{Methods}} for {{Estimating}} the {{Causal Effect}} of a {{Treatment}} in {{Randomized Clinical Trials Subject}} to {{Noncompliance}}},
	volume = {65},
	year = 2009}

@article{Little1989,
	abstract = {The detrimental effects of maternal drinking during pregnancy on fetal health have been documented. The consequences for infants of maternal drinking during breast-feeding are unknown, but research in animals suggests that the infant could be affected by exposure to alcohol through the mother's milk. In a study of 400 infants born to members of a health maintenance organization, we investigated the relation of the mother's use of alcohol during breast-feeding to the infant's development at one year of age. Mental development, as measured by the Bayley Mental Development Index (MDI), was unrelated to maternal drinking during breast-feeding. However, motor development, as measured by the Psychomotor Development Index (PDI), was significantly lower in infants exposed regularly to alcohol in breast milk (after alcohol exposure during gestation was controlled for), with a dose-response relation (P for linear trend, 0.006). The infants of breast-feeding mothers who had at least one drink daily had a mean PDI score of 98, whereas the infants exposed to less alcohol in breast milk had a mean PDI score of 103 (95 percent confidence interval for the difference of the two means, 1.2 to 9.8). The effect was more pronounced when mothers who supplemented breast-feeding with formula were excluded from the analysis. The association persisted even after we controlled for more than 100 potentially confounding variables, including smoking and other drug use during pregnancy and in the postpartum period. We conclude that ethanol ingested through breast milk has a slight but significant detrimental effect on motor development, but not mental development, in breast-fed infants.},
	author = {Little, R E and Anderson, K W and Ervin, C H and {Worthington-Roberts}, B and Clarren, S K},
	journal = {N Engl J Med},
	number = {7},
	pages = {425--430},
	title = {Maternal Alcohol Use during Breast-Feeding and Infant Mental and Motor Development at One Year},
	volume = {321},
	year = 1989}

