@article{Krieger2003,
	abstract = {Research on racism as a harmful determinant of population health is in its infancy. Explicitly naming a long-standing problem long recognized by those affected, this work has the potential to galvanize inquiry and action, much as the 1962 publication of the Kempe et al. scientific article on the "battered child syndrome" dramatically increased attention to-and prompted new research on-the myriad consequences of child abuse, a known yet neglected social phenomenon. To further work on connections between racism and health, the author addresses 3 interrelated issues: (1) links between racism, biology, and health; (2) methodological controversies over how to study the impact of racism on health; and (3) debates over whether racism or class underlies racial/ethnic disparities in health.},
	author = {Krieger, Nancy},
	journal = {Am J Public Health},
	number = {2},
	pages = {194--199},
	title = {Does Racism Harm Health? {{Did}} Child Abuse Exist before 1962? {{On}} Explicit Questions, Critical Science, and Current Controversies: An Ecosocial Perspective},
	volume = {93},
	year = 2003}

