	author = {Krieger, N. and Williams, D. R. and Moss, N. E.},
	journal = {Annu Rev Public Health},
	number = {1},
	pages = {341--378},
	title = {Measuring {{Social Class}} in {{US Public Health Research}}: {{Concepts}}, {{Methodologies}}, and {{Guidelines}}},
