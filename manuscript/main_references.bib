@article{Rockhill2005,
	abstract = {The dominant philosophy of modern epidemiology is individualism, despite the limitations of epidemiologic tools and methods when considering the individual level. We pursue information on increasingly reductionist causes in our search for knowledge of causes of specific cases. Philosophical reasoning and empiric evidence suggest that this search may not be as fruitful as proponents claim. I argue that using individualism to guide our search for causes of disease hinders our effectiveness in contributing to disease prevention, because the positive predictive values of most established genetic and environmental risk factors for noninfectious diseases are too low to be quantitatively convincing to an individual.},
	author = {Rockhill, Beverly},
	journal = {Epidemiol},
	number = {1},
	pages = {124--129},
	title = {Theorizing about Causes at the Individual Level While Estimating Effects at the Population Level: Implications for Prevention.},
	volume = {16},
	year = 2005}

@article{Rogawski2016,
	abstract = {PURPOSE: Although epidemiology has an indispensable role in serving public health, the relative emphasis of applications of epidemiology often tend toward individual-level medicine over public health in terms of resources and impact. METHODS: We make distinctions between public health and medical applications of epidemiology to raise awareness among epidemiologists, many of whom came to the field with public health in mind. We discuss reasons for the overemphasis on medical epidemiology and suggest ways to counteract these incentives. RESULTS: Public health epidemiology informs interventions that are applied to populations or that confer benefits beyond the individual, whereas medical epidemiology informs interventions that improve the health of treated individuals. Available resources, new biomedical technologies, and existing epidemiologic methods favor medical applications of epidemiology. Focus on public health impact and methods suited to answer public health questions can create better balance and promote population-level improvements in public health. CONCLUSIONS: By deliberately reflecting on research motivations and long-term goals, we hope the distinctions presented here will facilitate critical discussion and a greater consciousness of our potential impact on both individual and population-level health. Renewed intentions towards public health can help epidemiologists navigate potential projects and ultimately contribute to an epidemiology of consequence.},
	author = {Rogawski, Elizabeth T and Gray, Christine L and Poole, Charles},
	journal = {Annals of epidemiology},
	number = {10},
	pages = {729--733},
	title = {An Argument for Renewed Focus on Epidemiology for Public Health},
	volume = {26},
	year = 2016}

