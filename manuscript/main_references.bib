@article{Rubin1976,
	abstract = {SUMMARY When making sampling distribution inferences about the parameter of the data, \OE???, it is appropriate to ignore the process that causes missing data if the missing data are ???\"A\`omissing at random???\"A\^o and the observed data are ???\"A\`oobserved at random???\"A\^o, but these inferences are generally conditional on the observed pattern of missing data. When making direct-likelihood or Bayesian inferences about \OE???, it is appropriate to ignore the process that causes missing data if the missing data are missing at random and the parameter of the missing data process is ???\"A\`odistinct???\"A\^o from \OE???. These conditions are the weakest general conditions under which ignoring the process that causes missing data always leads to correct inferences.},
