@article{Pearl2010,
	abstract = {In 2 recent communications, Cole and Frangakis ( 2009;20:3???\"A\`i5) and VanderWeele ( 2009;20:880???\"A\`i883) conclude that the consistency rule used in causal inference is an assumption that precludes any side-effects of treatment/exposure on the outcomes of interest. They further develop auxiliary notation to make this assumption formal and explicit. I argue that the consistency rule is a theorem in the logic of counterfactuals and need not be altered. Instead, warnings of potential side-effects should be embodied in standard modeling practices that make causal assumptions explicit and transparent.},
	author = {Pearl, Judea},
	journal = {Epidemiol},
	number = {6},
	pages = {872--875},
	title = {On the {{Consistency Rule}} in {{Causal Inference}}: {{Axiom}}, {{Definition}}, {{Assumption}}, or {{Theorem}}?},
	volume = {21},
