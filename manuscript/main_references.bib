@article{Robinson1988,
	abstract = {One type of semiparametric regression on an {$<$}tex-math{$>\$\backslash$}scr\textbraceleft R\textbraceright\textasciicircum\textbraceleft p\textbraceright\textbackslash times \textbackslash scr\textbraceleft R\textbraceright\textasciicircum\textbraceleft q\textbraceright\textbackslash text\textbraceleft -valued\textbraceright\${$<$}/tex-math{$>$} random variable (X, Z) is {$\beta\prime$}X + \texttheta (Z), where {$\beta$} and \texttheta (Z) are an unknown slope coefficient vector and function, and X is neither wholly dependent on Z nor necessarily independent of it. Estimators of {$\beta$} based on incorrect parameterization of \texttheta{} are generally inconsistent, whereas consistent nonparametric estimators deviate from {$\beta$} by a larger probability order than N\textsuperscript{-1/2}, where N is sample size. An estimator generalizing the ordinary least squares estimator of {$\beta$} is constructed by inserting nonparametric regression estimators in the nonlinear orthogonal projection on Z. Under regularity conditions \^undefined is shown to be {$<$}tex-math{$>\$$}N\textasciicircum\textbraceleft 1/2\textbraceright\textbackslash text\textbraceleft -consistent\textbraceright\${$<$}/tex-math{$>$} for {$\beta$} and asymptotically normal, and a consistent estimator of its limiting covariance matrix is given, affording statistical inference that is not only asymptotically valid but has nonzero asymptotic first-order efficiency relative to estimators based on a correctly parameterized \texttheta. We discuss the identification problem and \^undefined's efficiency, and report results of a Monte Carlo study of finite-sample performance. While the paper focuses on the simplest interesting setting of multiple regression with independent observations, extensions to other econometric models are described, in particular seemingly unrelated and nonlinear regressions, simultaneous equations, distributed lags, and sample selectivity models.},
	author = {Robinson, P. M.},
	doi = {10.2307/1912705},
	eprint = {1912705},
	eprinttype = {jstor},
	issn = {0012-9682},
	journal = {Econometrica},
	number = {4},
	pages = {931--954},
	publisher = {[Wiley, Econometric Society]},
	title = {Root-{{N-Consistent Semiparametric Regression}}},
	urldate = {2025-05-02},
