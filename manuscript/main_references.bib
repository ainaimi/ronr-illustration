	author = {Gris, J. C. and Mercier, E. and Quere, I. and {Lavigne-Lissalde}, G. and {Cochery-Nouvellon}, E. and Hoffet, M. and {Ripart-Neveu}, S. and Tailland, M. L. and Dauzat, M. and Mares, P.},
