	author = {Thomas, Carrie E and Guillet, Ronnie and Queenan, Ruth A and Cooper, Elizabeth M and Kent, Tera R and Pressman, Eva K and Vermeylen, Francoise M and Roberson, Mark S and O'Brien, Kimberly O},
